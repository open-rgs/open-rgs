      → <a href="/build">Build something</a> &middot;
      <a href="/extend">Extend something</a> &middot;
      <a href="/boot">Boot</a> &middot;
      <a href="/wire">Wire</a> &middot;
      <a href="/complex">Complex rounds</a> &middot;
      <a href="/">Home</a>
    </nav>
  </main>
</BaseLayout>
